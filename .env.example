# Vercel Blob con OIDC se configura al conectar el almacén privado.

# Cuenta Gmail que enviará y recibirá los formularios.
GMAIL_USER=inmobiliariaactiva360@gmail.com

# Contraseña de aplicación de Google de 16 caracteres, sin espacios.
GMAIL_APP_PASSWORD=

# Ya no se utilizan OAuth ni Resend:
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
# RESEND_API_KEY=
# EMAIL_FROM=
# RECIPIENT_EMAIL=
